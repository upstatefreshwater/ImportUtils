# start work
git checkout dsa/TrollStability
git add / commit frequently
git push origin dsa/TrollStability

# integrate main only when necessary
git fetch origin
git merge origin/main   # safe and easy
# or
git rebase origin/main  # clean history, requires force push

# push branch after resolving conflicts
git push --force-with-lease origin dsa/TrollStability


