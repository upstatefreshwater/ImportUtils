Package: ImportUtils
Type: Package
Title: Data Import Utilities for UFI Field Equipment
Version: 0.1.0
Authors@R: c(
    person(
      "David", "Andrews",
      email = "dsandrews@upstatefreshwater.org",
      role = c("aut", "cre")
    )
  )
Description: Does a bunch of stuff. 
License: MIT + file LICENSE
Encoding: UTF-8
LazyData: true
Depends: 
    R (>= 3.5)
Imports:
    rlang,
    dplyr,
    tibble,
    lubridate,
	patchwork,
    purrr,
    ggplot2,
    cowplot,
	RColorBrewer,
    readr,
    stringr,
    zoo	
Suggests: 
    knitr,
    rmarkdown
VignetteBuilder: knitr
RoxygenNote: 7.3.3

